{
    "name": "Session Desktop",
    "app_path": [
        "/usr/bin/",
        "/opt/Session/",
        "/var/lib/flatpak/app/network.loki.Session/current/active/files/Session"
    ],
    "icons_path": [
        "/usr/lib/session-desktop/",
        "/opt/Session/resources/",
        "/var/lib/flatpak/app/network.loki.Session/current/active/files/Session/resources"
    ],
    "binary": "app.asar",
    "script": "electron",
    "icons": {
        "tray": {
            "original": "images/session/session_icon.png",
            "theme": "session-desktop-tray"
        },
        "tray-16": {
            "original": "images/session/session_icon_16.png",
            "theme": "session-desktop-tray"
        },
        "tray-32": {
            "original": "images/session/session_icon_32.png",
            "theme": "session-desktop-tray"
        }
    }
}
